# --- Local (host processes talking to published ports) ---
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# DATABASE_URL=postgresql+psycopg://alerts:alerts@localhost:5432/alerts
# WEBHOOK_URL=http://localhost:8080/alerts

# --- Docker Compose overrides these for in-network services ---
# alert-pipeline uses kafka:29092 and postgres:5432 automatically.
# Put secrets / toggle flags here; compose interpolates ${VAR} from this file.

KAFKA_INPUT_TOPIC=logs
KAFKA_CONSUMER_GROUP=alert-pipeline
KAFKA_AUTO_OFFSET_RESET=earliest

DEDUP_WINDOW_SECONDS=300
DEDUP_UPDATE_INTERVAL_SECONDS=60
ALERT_MIN_LEVEL=ERROR

DISPATCH_ENABLED=true

DISPATCH_ZENDUTY_ENABLED=false
ZENDUTY_INTEGRATION_KEY=
ZENDUTY_API_URL=https://www.zenduty.com/api/events

DISPATCH_TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Default in compose: true → http://webhook-debug:8080/alerts
DISPATCH_WEBHOOK_ENABLED=true
WEBHOOK_URL=http://webhook-debug:8080/alerts
WEBHOOK_HEADERS_JSON={"Content-Type":"application/json"}

LOG_LEVEL=INFO

ALERT_CONFIG_PATH=config/alerts.yaml

