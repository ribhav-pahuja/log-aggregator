# Copy to .env before `docker compose up`:
#   cp .env.example .env
#
# Compose REQUIRES POSTGRES_* and DATABASE_URL (no silent defaults).

# --- Postgres (also used to build DATABASE_URL for app services) ---
POSTGRES_USER=alerts
POSTGRES_PASSWORD=alerts
POSTGRES_DB=alerts

# In-compose network hostname is `postgres`. For host processes use localhost.
DATABASE_URL=postgresql+psycopg://alerts:alerts@postgres:5432/alerts

# --- Kafka ---
KAFKA_INPUT_TOPIC=logs
KAFKA_DLQ_TOPIC=logs-dlq
KAFKA_DLQ_ENABLED=true
KAFKA_CONSUMER_GROUP=alert-pipeline
KAFKA_AUTO_OFFSET_RESET=earliest

# Runtime is always Quix
# PIPELINE_RUNTIME=quix

# --- Dedup (quix = Quix keyed state; memory = unit tests only) ---
# Redis is NOT used for dedup — only for UI read cache.
DEDUP_BACKEND=quix
DEDUP_WINDOW_SECONDS=300
DEDUP_UPDATE_INTERVAL_SECONDS=60
ALERT_MIN_LEVEL=ERROR


# --- Dispatch (all opt-in for real destinations) ---
DISPATCH_ENABLED=true

DISPATCH_ZENDUTY_ENABLED=false
ZENDUTY_INTEGRATION_KEY=
ZENDUTY_API_URL=https://www.zenduty.com/api/events

DISPATCH_TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Local echo: set true and run webhook-debug (compose service)
DISPATCH_WEBHOOK_ENABLED=false
WEBHOOK_URL=http://webhook-debug:8080/alerts
WEBHOOK_HEADERS_JSON={"Content-Type":"application/json"}

LOG_LEVEL=INFO
ALERT_CONFIG_PATH=config/alerts.yaml

# --- Redis (UI cache + shared dedup) ---
# Host processes:
# REDIS_URL=redis://localhost:6379/0
UI_CACHE_TTL_SECONDS=10
UI_CACHE_LOCK_TTL_SECONDS=5
